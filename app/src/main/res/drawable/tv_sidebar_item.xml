<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active/selected section -->
    <item android:state_selected="true" android:state_focused="true">
        <layer-list>
            <item>
                <shape><solid android:color="#1E3D6B" /><corners android:radius="4dp" /></shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape><solid android:color="#008CFF" /></shape>
            </item>
            <item>
                <shape>
                    <stroke android:width="1dp" android:color="#008CFF" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape><solid android:color="#152B4A" /><corners android:radius="4dp" /></shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape><solid android:color="#008CFF" /></shape>
            </item>
        </layer-list>
    </item>
    <!-- Focused but not selected -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#33008CFF" />
            <stroke android:width="2dp" android:color="#008CFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#44008CFF" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item>
        <shape><solid android:color="@android:color/transparent" /></shape>
    </item>
</selector>
