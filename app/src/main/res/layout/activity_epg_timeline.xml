<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/timelineTopBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#1A1A1A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btnTimelineBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:text="← Guide"
            android:textColor="#008CFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="EPG TIMELINE"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <Button
            android:id="@+id/btnTimelineNow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:text="NOW ▶"
            android:textColor="#008CFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Header row: channel column spacer + time labels -->
    <LinearLayout
        android:id="@+id/timelineHeader"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:background="#141414"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timelineTopBar">

        <!-- Spacer matching channel column width -->
        <View
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="#1A1A1A" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A2A2A" />

        <HorizontalScrollView
            android:id="@+id/timeHeaderScroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/timeHeaderContent"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/timelineProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#008CFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timelineHeader" />

    <!-- Channel rows -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTimeline"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timelineHeader" />

</androidx.constraintlayout.widget.ConstraintLayout>
